# Optional. Without it, the app runs in mock mode (deterministic canned replies) — the demo and tests still work.
ANTHROPIC_API_KEY=
# Optional model override. Defaults to claude-haiku-4-5-20251001.
AI_MODEL=

# Web demo (web/server.js)
PORT=3000
# Optional cost caps for the hosted demo (defaults shown)
MAX_MESSAGES_PER_DAY=400
MAX_MESSAGES_PER_SESSION=15
